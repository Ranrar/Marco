[Desktop Entry]
Name=Marco
Comment=A GTK4-based markdown editor with custom syntax extensions
Exec=marco %F
Type=Application
MimeType=text/markdown;text/x-markdown;
Icon=marco
Categories=Office;TextEditor;
StartupNotify=true
Version=1.0
# Desktop Actions for context menu
Actions=Edit;View;

[Desktop Action Edit]
Name=Edit with Marco
Exec=marco %f
Icon=marco

[Desktop Action View]
Name=View with Polo
Exec=polo %f
Icon=marco
